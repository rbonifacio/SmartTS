contract SomaNumeros {
    storage: {
        total: int
    };

    @originate
    init(): unit {
        storage.total = 0;
        return ();
    }

    @entrypoint
    somaNumeros(max: int): int {
        storage.total = 0;
        for (var i: int = 1; i <= max; i = i + 1) {
            storage.total = storage.total + i;
        }
        return storage.total;
    }
}