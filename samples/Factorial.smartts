contract Factorial {
  storage: {
    result: int
  };

  @originate
  init(): unit {
    storage.result = 1;
    return ();
  }

  @entrypoint
  compute(n: int): int {
    storage.result = 1;
    for (var i: int = 1; i <= n; i = i + 1) {
      storage.result = storage.result * i;
    }
    return storage.result;
  }
}
