contract ListForEach {
  storage: {
    xs: list<int>,
    sum: int
  };

  @originate
  init(): unit {
    storage.xs = list<int>(1, 2, 3, 4);
    storage.sum = 0;
    return ();
  }

  @entrypoint
  recomputeSum(): int {
    var acc: int = 0;
    forEach(e: storage.xs) {
      acc = acc + e;
    }
    storage.sum = acc;
    return acc;
  }
}
